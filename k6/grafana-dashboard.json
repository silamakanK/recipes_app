{
  "title": "NutriSmart — Tests de charge",
  "uid": "nutrismart-load",
  "timezone": "browser",
  "time": { "from": "now-30m", "to": "now" },
  "refresh": "5s",
  "panels": [
    {
      "id": 1,
      "title": "Nombre de pods Next.js (HPA)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 8 },
      "targets": [
        {
          "expr": "kube_deployment_status_replicas{namespace=\"nutrismart\", deployment=\"nutrismart-nextjs\"}",
          "legendFormat": "Pods actifs",
          "refId": "A"
        },
        {
          "expr": "kube_horizontalpodautoscaler_spec_min_replicas{namespace=\"nutrismart\"}",
          "legendFormat": "Min (2)",
          "refId": "B"
        },
        {
          "expr": "kube_horizontalpodautoscaler_spec_max_replicas{namespace=\"nutrismart\"}",
          "legendFormat": "Max (5)",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "min": 0,
          "max": 6,
          "unit": "short"
        }
      },
      "options": { "tooltip": { "mode": "multi" } }
    },
    {
      "id": 2,
      "title": "Utilisation CPU Next.js (%)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(container_cpu_usage_seconds_total{namespace=\"nutrismart\", container=\"nextjs\"}[1m])) * 100",
          "legendFormat": "CPU total Next.js",
          "refId": "A"
        },
        {
          "expr": "vector(60)",
          "legendFormat": "Seuil HPA (60%)",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "min": 0,
          "unit": "percent"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Seuil HPA (60%)" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } },
              { "id": "custom.lineStyle", "value": { "dash": [10, 10], "fill": "dash" } }
            ]
          }
        ]
      }
    },
    {
      "id": 3,
      "title": "Utilisation mémoire Next.js (Mo)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(container_memory_usage_bytes{namespace=\"nutrismart\", container=\"nextjs\"}) / 1024 / 1024",
          "legendFormat": "RAM Next.js",
          "refId": "A"
        },
        {
          "expr": "vector(256)",
          "legendFormat": "Limite (256 Mo)",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "min": 0,
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Limite (256 Mo)" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } },
              { "id": "custom.lineStyle", "value": { "dash": [10, 10], "fill": "dash" } }
            ]
          }
        ]
      }
    }
  ],
  "schemaVersion": 38
}
